# Production Environment Configuration for Hostinger Deployment
# Copy this to Hostinger environment variables panel and fill in real values

# === Core Node/Environment ===
NODE_ENV=production
PORT=3000

# === Database (PostgreSQL) ===
# Use Hostinger's PostgreSQL database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/creditgenai_prod

# === Gemini API Configuration ===
# Get from https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_actual_gemini_api_key_here
VITE_GEMINI_API_KEY=your_actual_gemini_api_key_here

# === Email/SMTP Configuration ===
# For Gmail: Use App Password (not regular password)
# Settings > Security > 2-Step Verification > App passwords
# Set DISABLE_EMAIL=true to skip email functionality
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-not-regular-password
SMTP_FROM_NAME=CreditGenAI
SMTP_FROM_EMAIL=your-email@gmail.com
DISABLE_EMAIL=true

# === Twilio Configuration (WhatsApp) ===
# Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# === CORS Configuration ===
# Set your production domain(s)
# Format: https://yourdomain.com,https://api.yourdomain.com
ALLOWED_ORIGINS=https://yellow-fish-980264.hostingersite.com

# === Email/SMTP Configuration ===
# Set to true to disable email service (recommended for testing)
DISABLE_EMAIL=true
# Paste your Firebase config from Console > Project Settings
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# === Supabase Configuration (Optional) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
