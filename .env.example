# .env.example
# Gemini API Key (Vite convention: VITE_ prefix for client-side variables)
VITE_GEMINI_API_KEY=

# Admin Email (auto-promote user to admin)
ADMIN_EMAIL=admin@example.com

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
DATABASE_URL=

# SMTP Configuration for Email Notifications
# For Gmail: Use smtp.gmail.com, port 587, and an 'App Password'
# For Office 365: Use smtp.office365.com, port 587, and ensure 'SMTP AUTH' is enabled in Admin Center
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=CreditGenAI
SMTP_FROM_EMAIL=your-email@gmail.com

# Twilio Configuration for WhatsApp Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
