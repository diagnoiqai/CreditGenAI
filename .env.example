# .env.example
# Gemini API Key (handled by platform)
GEMINI_API_KEY=

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
DATABASE_URL=

# SMTP Configuration for Email Notifications
# For Gmail: Use smtp.gmail.com, port 587, and an 'App Password'
# For Office 365: Use smtp.office365.com, port 587. 
# IMPORTANT: You MUST enable 'Authenticated SMTP' for the mailbox in Microsoft 365 Admin Center.
# If you see error 535 5.7.139, it means 'Security Defaults' are blocking basic SMTP.
# You may need to use an 'App Password' if MFA is enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=CreditGenAI
SMTP_FROM_EMAIL=your-email@gmail.com
DISABLE_EMAIL=true

# Twilio Configuration for WhatsApp Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
